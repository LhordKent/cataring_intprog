<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Temu_Catarig.Pages.OrderFulfillmentPage"
             Shell.NavBarIsVisible="False"
             Title="Order Fulfillment"
             BackgroundColor="#121212">

    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        <!-- Mock Phone Frame -->
        <Frame WidthRequest="360" 
               HeightRequest="640" 
               Padding="0" 
               CornerRadius="20" 
               IsClippedToBounds="True" 
               HasShadow="True" 
               BackgroundColor="#F8F8F8"
               BorderColor="Black">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Back Button -->
                <Grid Grid.Row="0" BackgroundColor="White" Padding="15,10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="←" FontSize="24" TextColor="Black" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="Order Fulfillment" TextColor="Black" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Grid>

                <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="15" Spacing="15">
                    <Label Text="Pending Orders" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                    
                    <Label x:Name="NoOrdersLabel" 
                           Text="No orders to fulfill yet" 
                           HorizontalOptions="Center" 
                           Margin="0,50,0,0" 
                           TextColor="Gray"
                           IsVisible="False"/>

                    <CollectionView x:Name="OrdersCollection">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="White" Padding="15" HasShadow="False" CornerRadius="10" Margin="0,0,0,10">
                                    <VerticalStackLayout Spacing="10">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Grid.Column="0" Text="{Binding ShortId, StringFormat='Order #{0}'}" TextColor="Black" FontAttributes="Bold"/>
                                            <Label Grid.Column="1" Text="{Binding Status}" TextColor="{Binding StatusColor}" FontAttributes="Bold" FontSize="12"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#EEEEEE"/>
                                        <Label Text="{Binding FirstItemName, StringFormat='Item: {0}'}" TextColor="Black" FontSize="14"/>
                                        
                                        <Button Text="{Binding FulfillmentButtonText}" 
                                                BackgroundColor="{StaticResource Primary}" 
                                                TextColor="White" FontSize="12" 
                                                FontAttributes="Bold" 
                                                HeightRequest="35" 
                                                HorizontalOptions="End"
                                                IsVisible="{Binding IsFulfillmentActionVisible}"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnFulfillClicked"/>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
