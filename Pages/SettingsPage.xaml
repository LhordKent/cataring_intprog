<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Temu_Catarig.Pages.SettingsPage"
             Shell.NavBarIsVisible="False"
             Title="Settings"
             BackgroundColor="#121212">

    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        <!-- Mock Phone Frame -->
        <Frame WidthRequest="360" 
               HeightRequest="640" 
               Padding="0" 
               CornerRadius="20" 
               IsClippedToBounds="True" 
               HasShadow="True" 
               BackgroundColor="#F8F8F8"
               BorderColor="Black">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Back Button -->
                <Grid Grid.Row="0" BackgroundColor="White" Padding="15,10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="←" FontSize="24" TextColor="Black" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="Settings" TextColor="Black" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Grid>

                <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="15" Spacing="15">
                    <Label Text="General" TextColor="Gray" FontSize="12" Margin="5,0"/>
                    
                    <Frame BackgroundColor="White" Padding="0" HasShadow="False" CornerRadius="10">
                        <VerticalStackLayout>
                            <Grid Padding="15" ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Push Notifications" TextColor="Black" VerticalOptions="Center"/>
                                <Switch Grid.Column="1" IsToggled="True" OnColor="{StaticResource Primary}"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </ScrollView>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
