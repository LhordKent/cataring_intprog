<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Temu_Catarig.Pages.ContactUsPage"
             Shell.NavBarIsVisible="False"
             Title="Contact Us"
             BackgroundColor="#121212">

    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        <!-- Mock Phone Frame -->
        <Frame WidthRequest="360" 
               HeightRequest="640" 
               Padding="0" 
               CornerRadius="20" 
               IsClippedToBounds="True" 
               HasShadow="True" 
               BackgroundColor="White"
               BorderColor="Black">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Back Button -->
                <Grid Grid.Row="0" BackgroundColor="White" Padding="15,10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="←" FontSize="24" TextColor="Black" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="Contact Us" TextColor="Black" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Grid>

                <VerticalStackLayout Grid.Row="1" Padding="30" Spacing="25" VerticalOptions="Center">
                
                <Frame BackgroundColor="{StaticResource Primary}" 
                       HeightRequest="100" WidthRequest="100" 
                       CornerRadius="50" HorizontalOptions="Center" 
                       Padding="0" HasShadow="True">
                    <Label Text="👨‍💻" FontSize="50" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>

                <Label Text="Developer Information" 
                       FontSize="24" FontAttributes="Bold" 
                       TextColor="Black" HorizontalOptions="Center"/>
                
                <BoxView HeightRequest="1" Color="{StaticResource Primary}" WidthRequest="200" HorizontalOptions="Center"/>

                <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="👤" FontSize="20" VerticalOptions="Center"/>
                        <Label Text="John Adrian Catarig" TextColor="Black" FontSize="18" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15">
                        <Label Text="📧" FontSize="20" VerticalOptions="Center"/>
                        <Label Text="johnadriancatarig@gmail.com" TextColor="Black" FontSize="16" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
