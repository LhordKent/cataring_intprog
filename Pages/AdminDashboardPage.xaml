<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Temu_Catarig.Pages.AdminDashboardPage"
             Shell.NavBarIsVisible="False"
             Title="Admin Dashboard"
             BackgroundColor="#121212">

    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        <Frame WidthRequest="360" 
               HeightRequest="640" 
               Padding="0" 
               CornerRadius="20" 
               IsClippedToBounds="True" 
               HasShadow="True" 
               BackgroundColor="#F8F8F8"
               BorderColor="Black">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" BackgroundColor="White" Padding="20">
                    <Label Text="Admin Dashboard" FontSize="20" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center"/>
                </Grid>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Padding="20" Spacing="15">
                        <Label Text="Pending Approvals" FontSize="16" FontAttributes="Bold" TextColor="Black"/>
                        
                        <CollectionView x:Name="PendingCollection">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="White" Padding="15" HasShadow="False" CornerRadius="10" Margin="0,0,0,10">
                                        <VerticalStackLayout Spacing="10">
                                            <Grid ColumnDefinitions="60, *" ColumnSpacing="15">
                                                <Image Grid.Column="0" Source="{Binding ImageUrl}" HeightRequest="60" WidthRequest="60" Aspect="AspectFill"/>
                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                    <Label Text="{Binding Title}" TextColor="Black" FontAttributes="Bold"/>
                                                    <Label Text="{Binding Price, StringFormat='₱{0:N0}'}" TextColor="Gray"/>
                                                </VerticalStackLayout>
                                            </Grid>
                                            
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                                <Button Grid.Column="0" Text="REJECT" BackgroundColor="#FFEBEE" TextColor="#D32F2F" FontAttributes="Bold" Clicked="OnRejectClicked" CommandParameter="{Binding .}"/>
                                                <Button Grid.Column="1" Text="APPROVE" BackgroundColor="#E8F5E9" TextColor="#388E3C" FontAttributes="Bold" Clicked="OnApproveClicked" CommandParameter="{Binding .}"/>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>

                <Button Grid.Row="2" Text="LOGOUT" BackgroundColor="Black" TextColor="White" Margin="20" Clicked="OnLogoutClicked"/>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
