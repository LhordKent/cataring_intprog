<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Temu_Catarig.Pages.EditProfilePage"
             Shell.NavBarIsVisible="False"
             Title="Edit Profile"
             BackgroundColor="#121212">

    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        <Frame WidthRequest="360" 
               HeightRequest="640" 
               Padding="0" 
               CornerRadius="20" 
               IsClippedToBounds="True" 
               HasShadow="True" 
               BackgroundColor="#F8F8F8"
               BorderColor="Black">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" BackgroundColor="White" Padding="15,10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="←" FontSize="24" TextColor="Black" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="Edit Profile" TextColor="Black" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Form -->
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Padding="20" Spacing="15">
                        <Label Text="Full Name" TextColor="Black" FontAttributes="Bold"/>
                        <Entry x:Name="NameEntry" Placeholder="Enter your full name" TextColor="Black" BackgroundColor="White"/>

                        <Label Text="Phone Number" TextColor="Black" FontAttributes="Bold"/>
                        <Entry x:Name="PhoneEntry" Placeholder="Enter phone number" Keyboard="Numeric" TextColor="Black" BackgroundColor="White"/>

                        <Label Text="Shipping Address" TextColor="Black" FontAttributes="Bold"/>
                        <Editor x:Name="AddressEditor" Placeholder="Enter shipping address" HeightRequest="100" TextColor="Black" BackgroundColor="White"/>

                        <Label Text="Email (Read-only)" TextColor="Black" FontAttributes="Bold"/>
                        <Entry x:Name="EmailEntry" IsReadOnly="True" TextColor="Gray" BackgroundColor="#EEEEEE"/>

                        <Button Text="SAVE CHANGES"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                FontAttributes="Bold"
                                HeightRequest="50"
                                CornerRadius="25"
                                Margin="0,20,0,0"
                                Clicked="OnSaveClicked"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>