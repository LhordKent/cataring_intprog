<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Temu_Catarig.Pages.MyOrdersPage"
             Shell.NavBarIsVisible="False"
             Title="My Orders"
             BackgroundColor="#121212">

    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        <!-- Mock Phone Frame -->
        <Frame WidthRequest="360" 
               HeightRequest="640" 
               Padding="0" 
               CornerRadius="20" 
               IsClippedToBounds="True" 
               HasShadow="True" 
               BackgroundColor="#F8F8F8"
               BorderColor="Black">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Back Button -->
                <Grid Grid.Row="0" BackgroundColor="White" Padding="15,10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="←" FontSize="24" TextColor="Black" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="My Orders" TextColor="Black" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Grid>

                <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="15" Spacing="15">
                    
                    <Label x:Name="NoOrdersLabel" 
                           Text="No orders yet" 
                           HorizontalOptions="Center" 
                           Margin="0,50,0,0" 
                           TextColor="Gray"
                           IsVisible="False"/>

                    <CollectionView x:Name="OrdersCollection">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="White" Padding="15" HasShadow="False" CornerRadius="10" Margin="0,0,0,15">
                                    <VerticalStackLayout Spacing="10">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Grid.Column="0" Text="{Binding ShortId, StringFormat='Order #{0}'}" TextColor="Black" FontAttributes="Bold"/>
                                            <Label Grid.Column="1" Text="{Binding Status}" TextColor="{Binding StatusColor}" FontAttributes="Bold" FontSize="12"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#EEEEEE"/>
                                        <Grid ColumnDefinitions="60, *" ColumnSpacing="15">
                                            <Image Grid.Column="0" Source="{Binding FirstItemImage}" HeightRequest="60" WidthRequest="60" Aspect="AspectFill" BackgroundColor="#EEEEEE"/>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                <Label Text="{Binding FirstItemName}" TextColor="Black" FontSize="14"/>
                                                <Label Text="{Binding TotalAmount, StringFormat='Total: ${0:F2}'}" TextColor="Black" FontAttributes="Bold" Margin="0,5,0,0"/>
                                                
                                                <Button Text="REVIEW" 
                                                        BackgroundColor="{StaticResource Primary}" 
                                                        TextColor="White" 
                                                        FontSize="12" 
                                                        FontAttributes="Bold" 
                                                        HeightRequest="30" 
                                                        WidthRequest="100"
                                                        HorizontalOptions="Start"
                                                        Margin="0,10,0,0"
                                                        IsVisible="{Binding ShowReviewButton}"
                                                        CommandParameter="{Binding .}"
                                                        Clicked="OnReviewClicked"/>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
