<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Temu_Catarig.Pages.ProfilePage"
             Shell.NavBarIsVisible="False"
             Title="My Profile"
             BackgroundColor="#121212">

    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        <!-- Mock Phone Frame -->
        <Frame WidthRequest="360" 
               HeightRequest="640" 
               Padding="0" 
               CornerRadius="20" 
               IsClippedToBounds="True" 
               HasShadow="True" 
               BackgroundColor="#F8F8F8"
               BorderColor="Black">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollView Grid.Row="0">
                    <VerticalStackLayout Spacing="0">
                        <!-- Profile Header -->
                        <Grid BackgroundColor="{StaticResource Primary}" Padding="30" RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, *">
                            <Frame Grid.RowSpan="2" Grid.Column="0" 
                                   HeightRequest="80" WidthRequest="80" 
                                   CornerRadius="40" Padding="0" 
                                   BackgroundColor="White" HasShadow="True">
                                <Label Text="👤" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                            
                            <Label Grid.Row="0" Grid.Column="1" 
                                   x:Name="UserNameLabel"
                                   Text="{Binding DisplayName}" 
                                   TextColor="White" FontSize="20" 
                                   FontAttributes="Bold" 
                                   VerticalOptions="End" Margin="20,0,0,0"/>
                            <Label Grid.Row="1" Grid.Column="1" 
                                   Text="{Binding PhoneNumber}" 
                                   TextColor="#FFCCBC" 
                                   FontSize="14" 
                                   VerticalOptions="Start" Margin="20,5,0,0"/>
                        </Grid>

                        <!-- Menu Options -->
                        <VerticalStackLayout Padding="15" Spacing="10">
                            <Label Text="Account Settings" TextColor="Gray" FontSize="12" Margin="5,10,0,5"/>
                            
                            <Frame BackgroundColor="White" Padding="0" HasShadow="False" CornerRadius="10">
                                <VerticalStackLayout>
                                    <Grid Padding="15" ColumnDefinitions="Auto, *, Auto">
                                        <Label Grid.Column="0" Text="👤" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="Profile" TextColor="Black" VerticalOptions="Center" Margin="15,0,0,0"/>
                                        <Label Grid.Column="2" Text="›" TextColor="Gray" FontSize="20" VerticalOptions="Center"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnProfileClicked"/>
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>
                                    <Grid Padding="15" ColumnDefinitions="Auto, *, Auto">
                                        <Label Grid.Column="0" Text="📦" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="My Orders" TextColor="Black" VerticalOptions="Center" Margin="15,0,0,0"/>
                                        <Label Grid.Column="2" Text="›" TextColor="Gray" FontSize="20" VerticalOptions="Center"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnOrdersClicked"/>
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>

                            <!-- Seller Access -->
                            <Label Text="Seller Tools" TextColor="Gray" FontSize="12" Margin="5,10,0,5"/>
                            <Frame BackgroundColor="White" Padding="0" HasShadow="False" CornerRadius="10">
                                <VerticalStackLayout>
                                    <Grid Padding="15" ColumnDefinitions="Auto, *, Auto">
                                        <Label Grid.Column="0" Text="🏬" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="Order Fulfillment" TextColor="Black" VerticalOptions="Center" Margin="15,0,0,0"/>
                                        <Label Grid.Column="2" Text="›" TextColor="Gray" FontSize="20" VerticalOptions="Center"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnFulfillmentClicked"/>
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>
                                    <Grid Padding="15" ColumnDefinitions="Auto, *, Auto">
                                        <Label Grid.Column="0" Text="➕" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="Add New Product" TextColor="Black" VerticalOptions="Center" Margin="15,0,0,0"/>
                                        <Label Grid.Column="2" Text="›" TextColor="Gray" FontSize="20" VerticalOptions="Center"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnAddNewProductClicked"/>
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>
                                    <Grid Padding="15" ColumnDefinitions="Auto, *, Auto">
                                        <Label Grid.Column="0" Text="📝" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="Manage Products" TextColor="Black" VerticalOptions="Center" Margin="15,0,0,0"/>
                                        <Label Grid.Column="2" Text="›" TextColor="Gray" FontSize="20" VerticalOptions="Center"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnManageProductsClicked"/>
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>

                            <Button Text="Logout" 
                                    TextColor="Red" 
                                    BackgroundColor="Transparent" 
                                    Margin="0,20,0,0"
                                    Clicked="OnLogoutClicked"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- INTERNAL NAVIGATION BAR -->
                <Frame Grid.Row="1" BackgroundColor="White" Padding="0" HeightRequest="60" HasShadow="True" BorderColor="#EEEEEE" CornerRadius="0">
                    <Grid ColumnDefinitions="*, *, *">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="🏠" HorizontalOptions="Center" FontSize="20" TextColor="Gray"/>
                            <Label Text="Home" HorizontalOptions="Center" FontSize="10" TextColor="Gray"/>
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnHomeClicked"/>
                            </VerticalStackLayout.GestureRecognizers>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="🛒" HorizontalOptions="Center" FontSize="20" TextColor="Gray"/>
                            <Label Text="Cart" HorizontalOptions="Center" FontSize="10" TextColor="Gray"/>
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCartClicked"/>
                            </VerticalStackLayout.GestureRecognizers>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                            <Label Text="👤" HorizontalOptions="Center" FontSize="20" TextColor="{StaticResource Primary}"/>
                            <Label Text="Profile" HorizontalOptions="Center" FontSize="10" TextColor="{StaticResource Primary}" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
