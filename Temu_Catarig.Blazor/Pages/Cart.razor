@page "/checkout"
@inject FirebaseService FirebaseService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Checkout | Temu</PageTitle>

<div class="max-w-4xl mx-auto py-8 px-4">
    <h1 class="text-2xl font-bold mb-8">Checkout</h1>

    @if (isPlacingOrder)
    {
        <div class="text-center py-20">
            <svg class="animate-spin h-12 w-12 mx-auto text-temu-orange mb-4" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <p class="text-gray-600 font-medium">Placing your order...</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                <!-- Shipping Address -->
                <section class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                        Shipping Address
                    </h2>
                    <div class="space-y-4">
                        <input type="text" placeholder="Full Name" @bind="profile.FullName"
                               class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-temu-orange/20" />
                        <input type="text" placeholder="Phone Number" @bind="profile.PhoneNumber"
                               class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-temu-orange/20" />
                        <textarea placeholder="Complete Address" @bind="profile.ShippingAddress" rows="3"
                                  class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-temu-orange/20"></textarea>
                    </div>
                </section>

                <!-- Payment Method -->
                <section class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10"/></svg>
                        Payment Method
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <button class="p-4 border-2 rounded-xl text-left border-temu-orange bg-temu-orange/5">
                            <span class="font-bold block">Cash on Delivery</span>
                            <span class="text-xs text-gray-500">Pay when you receive the package</span>
                        </button>
                        <button class="p-4 border-2 rounded-xl text-left border-gray-100 hover:border-gray-200 bg-gray-50 opacity-50 cursor-not-allowed">
                            <span class="font-bold block">GCash / Card</span>
                            <span class="text-xs text-gray-500 italic">Coming Soon</span>
                        </button>
                    </div>
                </section>
            </div>

            <div class="lg:col-span-1">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 sticky top-24">
                    <h2 class="text-lg font-bold mb-4">Order Summary</h2>
                    <div class="space-y-3 text-sm text-gray-600 mb-6">
                        @foreach (var item in cartItems)
                        {
                            <div class="flex justify-between">
                                <span class="truncate pr-4">@item.Quantity x @item.Title</span>
                                <span class="flex-shrink-0 font-medium">₱@((item.Price * item.Quantity).ToString("N0"))</span>
                            </div>
                        }
                        <div class="pt-3 border-t border-gray-100 flex justify-between text-lg font-bold text-gray-900">
                            <span>Total</span>
                            <span class="text-temu-orange">₱@Subtotal.ToString("N0")</span>
                        </div>
                    </div>
                    <button @onclick="PlaceOrder" 
                            disabled="@(cartItems.Count == 0 || string.IsNullOrEmpty(profile.ShippingAddress))"
                            class="w-full btn-primary py-3 font-bold text-lg disabled:opacity-50">
                        PLACE ORDER
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<CartItem> cartItems = new();
    private UserProfile profile = new();
    private bool isPlacingOrder;
    private double Subtotal => cartItems.Sum(i => i.Price * i.Quantity);

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        cartItems = await FirebaseService.GetCartItemsAsync(AuthService.UserId!);
        if (!cartItems.Any())
        {
            Navigation.NavigateTo("/cart");
            return;
        }

        profile = await FirebaseService.GetUserProfileAsync(AuthService.UserId!);
    }

    private async Task PlaceOrder()
    {
        isPlacingOrder = true;

        // Group items by seller for order splitting
        var ordersBySeller = cartItems.GroupBy(i => i.SellerId);

        foreach (var group in ordersBySeller)
        {
            var sellerItems = group.ToList();
            var sellerSubtotal = sellerItems.Sum(i => i.Price * i.Quantity);

            var order = new Order
            {
                BuyerId = AuthService.UserId!,
                SellerId = group.Key,
                SellerName = sellerItems[0].SellerName,
                Items = sellerItems,
                Subtotal = sellerSubtotal,
                ShippingFee = 0,
                TotalPrice = sellerSubtotal,
                Status = "Pending",
                OrderDate = DateTime.Now,
                ReceiverName = profile.FullName,
                ReceiverPhone = profile.PhoneNumber,
                ShippingAddress = profile.ShippingAddress
            };

            await FirebaseService.PlaceOrderAsync(order);
        }

        // Clear cart and save profile
        await FirebaseService.ClearCartAsync(AuthService.UserId!);
        await FirebaseService.SaveUserProfileAsync(profile);

        Navigation.NavigateTo("/"); // Future: Order success page
        isPlacingOrder = false;
    }
}
