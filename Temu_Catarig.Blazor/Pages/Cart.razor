@page "/cart"
@inject FirebaseService FirebaseService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Your Cart | Temu</PageTitle>

<div class="max-w-6xl mx-auto py-8 px-4">
    <h1 class="text-2xl font-bold mb-8">Shopping Cart (@cartItems.Count)</h1>

    @if (cartItems == null)
    {
        <div class="space-y-4">
            @for (int i = 0; i < 3; i++)
            {
                <div class="h-32 bg-gray-100 animate-pulse rounded-xl"></div>
            }
        </div>
    }
    else if (!cartItems.Any())
    {
        <div class="text-center py-20 bg-white rounded-2xl border border-dashed border-gray-200">
            <div class="text-6xl mb-4">🛒</div>
            <h2 class="text-xl font-bold text-gray-800 mb-2">Your cart is empty</h2>
            <p class="text-gray-500 mb-8">Looks like you haven't added anything to your cart yet.</p>
            <NavLink href="/" class="btn-primary py-3 px-12">Start Shopping</NavLink>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Cart Items -->
            <div class="lg:col-span-2 space-y-4">
                @foreach (var item in cartItems)
                {
                    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex gap-4">
                        <img src="@item.ImageUrl" class="w-24 h-24 object-cover rounded-lg flex-shrink-0" alt="@item.Title" />
                        
                        <div class="flex-1 flex flex-col">
                            <div class="flex justify-between gap-4 mb-1">
                                <h3 class="text-sm font-medium text-gray-900 line-clamp-2">@item.Title</h3>
                                <button @onclick="() => RemoveItem(item.ProductId)" class="text-gray-400 hover:text-red-500">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                                </button>
                            </div>
                            
                            <div class="text-xs text-gray-500 mb-auto">Seller: @item.SellerName</div>
                            
                            <div class="flex items-center justify-between mt-4">
                                <span class="text-lg font-bold text-temu-orange">₱@item.Price.ToString("N0")</span>
                                
                                <div class="flex items-center border border-gray-200 rounded-lg overflow-hidden">
                                    <button @onclick="() => UpdateQuantity(item, -1)" class="px-3 py-1 bg-gray-50 hover:bg-gray-100 text-gray-600 font-bold">-</button>
                                    <span class="px-4 py-1 text-sm font-medium w-12 text-center">@item.Quantity</span>
                                    <button @onclick="() => UpdateQuantity(item, 1)" class="px-3 py-1 bg-gray-50 hover:bg-gray-100 text-gray-600 font-bold">+</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Summary -->
            <div class="lg:col-span-1">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 sticky top-24">
                    <h2 class="text-lg font-bold mb-6">Order Summary</h2>
                    
                    <div class="space-y-4 mb-6">
                        <div class="flex justify-between text-gray-600">
                            <span>Subtotal</span>
                            <span>₱@Subtotal.ToString("N0")</span>
                        </div>
                        <div class="flex justify-between text-gray-600">
                            <span>Shipping</span>
                            <span class="text-green-600 font-medium">FREE</span>
                        </div>
                        <div class="pt-4 border-t border-gray-100 flex justify-between text-xl font-bold text-gray-900">
                            <span>Total</span>
                            <span class="text-temu-orange">₱@Subtotal.ToString("N0")</span>
                        </div>
                    </div>
                    
                    <button @onclick="GoToCheckout" class="w-full btn-primary py-4 font-bold text-lg shadow-lg shadow-temu-orange/20">
                        CHECKOUT
                    </button>
                    
                    <div class="mt-6 flex flex-col gap-3">
                        <div class="flex items-center gap-2 text-[10px] text-gray-400 uppercase tracking-wider font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            Secure Checkout
                        </div>
                        <div class="flex items-center gap-2 text-[10px] text-gray-400 uppercase tracking-wider font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                            Free Returns
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<CartItem> cartItems = new();
    private double Subtotal => cartItems.Sum(i => i.Price * i.Quantity);

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadCart();
    }

    private async Task LoadCart()
    {
        cartItems = await FirebaseService.GetCartItemsAsync(AuthService.UserId!);
    }

    private async Task UpdateQuantity(CartItem item, int delta)
    {
        item.Quantity += delta;
        if (item.Quantity < 1) item.Quantity = 1;
        if (item.Quantity > 99) item.Quantity = 99;

        await FirebaseService.AddToCartAsync(AuthService.UserId!, item);
        await LoadCart();
    }

    private async Task RemoveItem(string productId)
    {
        await FirebaseService.RemoveFromCartAsync(AuthService.UserId!, productId);
        await LoadCart();
    }

    private void GoToCheckout()
    {
        Navigation.NavigateTo("/checkout");
    }
}
