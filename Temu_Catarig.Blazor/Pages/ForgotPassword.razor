@page "/forgot-password"
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Forgot Password | Temu</PageTitle>

<div class="flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-2xl shadow-sm border border-gray-100">
        <div class="text-center">
            <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Forgot Password</h1>
            <p class="text-gray-500 text-sm">Enter your Gmail to receive a reset link</p>
        </div>

        @if (isSubmitted)
        {
            <div class="bg-green-50 border-l-4 border-green-400 p-4 text-green-700 text-sm">
                <p>If an account exists for <b>@email</b>, you will receive a reset link shortly.</p>
            </div>
            <div class="text-center mt-6">
                <NavLink href="/login" class="text-gray-500 hover:text-temu-orange transition-colors">Back to Login</NavLink>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="bg-red-50 border-l-4 border-red-400 p-4 text-red-700 text-sm">
                    @errorMessage
                </div>
            }

            <div class="mt-8 space-y-6">
                <div>
                    <input type="email" @bind="email" 
                           class="appearance-none block w-full px-4 py-3 bg-gray-50 border border-transparent rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-temu-orange/20 focus:bg-white transition-all sm:text-sm" 
                           placeholder="Gmail" />
                </div>

                <button @onclick="HandleReset" disabled="@(isSubmitting || string.IsNullOrEmpty(email))"
                        class="w-full flex justify-center py-4 px-4 border border-transparent text-sm font-bold rounded-full text-white bg-temu-orange hover:bg-opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-temu-orange disabled:opacity-50 transition-all uppercase">
                    @if (isSubmitting)
                    {
                        <svg class="animate-spin h-5 w-5 mr-3 text-white" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    }
                    Send Reset Link
                </button>

                <div class="text-center">
                    <NavLink href="/login" class="text-gray-500 hover:text-temu-orange transition-colors text-sm">Back to Login</NavLink>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string email = string.Empty;
    private string? errorMessage;
    private bool isSubmitting;
    private bool isSubmitted;

    private async Task HandleReset()
    {
        errorMessage = null;
        isSubmitting = true;

        var result = await AuthService.ResetPassword(email);
        
        if (result.Success)
        {
            isSubmitted = true;
        }
        else
        {
            errorMessage = result.ErrorMessage;
        }

        isSubmitting = false;
    }
}
