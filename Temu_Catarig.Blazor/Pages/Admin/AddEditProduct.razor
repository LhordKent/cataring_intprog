@page "/admin/product/add"
@page "/admin/product/edit/{Id}"
@inject FirebaseService FirebaseService
@inject ImageService ImageService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>@(string.IsNullOrEmpty(Id) ? "Add Product" : "Edit Product") | Temu</PageTitle>

<div class="max-w-4xl mx-auto py-8 px-4">
    <div class="mb-8 flex items-center gap-4">
        <button @onclick="GoBack" class="p-2 hover:bg-gray-100 rounded-full transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <h1 class="text-2xl font-bold">@(string.IsNullOrEmpty(Id) ? "Add New Product" : "Edit Product")</h1>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center py-20">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-temu-orange"></div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <!-- Left: Image Upload -->
            <div class="space-y-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Product Image</label>
                <div class="relative group aspect-square rounded-xl bg-gray-50 border-2 border-dashed border-gray-200 flex flex-col items-center justify-center overflow-hidden transition-colors hover:border-temu-orange/50">
                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <img src="@product.ImageUrl" class="w-full h-full object-cover" alt="Product preview" />
                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                            <label class="cursor-pointer bg-white text-black px-4 py-2 rounded-full text-sm font-medium">
                                Change Image
                                <InputFile OnChange="HandleFileSelected" class="hidden" accept="image/*" />
                            </label>
                        </div>
                    }
                    else if (isUploading)
                    {
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-temu-orange"></div>
                        <p class="mt-2 text-sm text-gray-500">Uploading...</p>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-300 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        <p class="text-sm text-gray-500 text-center px-4">Click to upload product image</p>
                        <InputFile OnChange="HandleFileSelected" class="absolute inset-0 opacity-0 cursor-pointer" accept="image/*" />
                    }
                </div>
                <p class="text-xs text-gray-400">Recommended: Square image, max 5MB.</p>
            </div>

            <!-- Right: Form Fields -->
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Product Name</label>
                    <input @bind="product.Title" type="text" placeholder="Enter product name" 
                           class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Price (₱)</label>
                        <input @bind="product.Price" type="number" placeholder="0.00" 
                               class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Stock</label>
                        <input @bind="product.Stock" type="number" placeholder="0" 
                               class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                    <select @bind="product.Category" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all appearance-none">
                        <option value="General">General</option>
                        <option value="Electronics">Electronics</option>
                        <option value="Fashion">Fashion</option>
                        <option value="Home">Home</option>
                        <option value="Beauty">Beauty</option>
                        <option value="Sports">Sports</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                    <textarea @bind="product.Description" rows="4" placeholder="Enter product details..." 
                              class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all resize-none"></textarea>
                </div>

                <div class="pt-4">
                    <button @onclick="SaveProduct" disabled="@isSaving"
                            class="w-full py-3 bg-temu-orange text-white rounded-full font-bold shadow-lg shadow-temu-orange/20 hover:bg-orange-600 transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                        @if (isSaving)
                        {
                            <span class="inline-block animate-spin mr-2">◌</span>
                            <span>SAVING...</span>
                        }
                        else
                        {
                            <span>@(string.IsNullOrEmpty(Id) ? "ADD PRODUCT" : "UPDATE PRODUCT")</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }

    private Product product = new();
    private bool isLoading = true;
    private bool isUploading = false;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (!string.IsNullOrEmpty(Id))
        {
            var existing = await FirebaseService.GetProductByIdAsync(Id);
            if (existing != null)
            {
                product = existing;
            }
            else
            {
                Navigation.NavigateTo("/admin/dashboard");
            }
        }
        
        isLoading = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        isUploading = true;
        try
        {
            var url = await ImageService.UploadImageAsync(e.File);
            if (!string.IsNullOrEmpty(url))
            {
                product.ImageUrl = url;
            }
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(product.Title) || product.Price <= 0)
        {
            // Simple validation
            return;
        }

        if (string.IsNullOrEmpty(product.ImageUrl))
        {
            // Must have image
            return;
        }

        isSaving = true;
        try
        {
            product.SellerId = AuthService.UserId ?? "Unknown";
            product.SellerName = AuthService.UserDisplayName ?? "Seller";

            if (string.IsNullOrEmpty(Id))
            {
                await FirebaseService.AddProductAsync(product);
            }
            else
            {
                await FirebaseService.UpdateProductAsync(product);
            }

            Navigation.NavigateTo("/admin/dashboard");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving product: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/admin/dashboard");
}
