@page "/checkout"
@inject FirebaseService FirebaseService
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Checkout | Temu</PageTitle>

<div class="max-w-xl mx-auto pb-24 min-h-screen flex flex-col">
    <!-- Header -->
    <div class="sticky top-0 z-10 bg-white border-b border-gray-100 px-4 py-4 flex items-center gap-4">
        <button @onclick='() => Navigation.NavigateTo("/cart")' class="p-2 hover:bg-gray-100 rounded-full transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <h1 class="text-xl font-bold text-gray-800">Checkout</h1>
    </div>

    @if (isPlacingOrder)
    {
        <div class="flex-1 flex flex-col items-center justify-center py-20 gap-4">
            <div class="w-12 h-12 border-4 border-temu-orange border-t-transparent rounded-full animate-spin"></div>
            <p class="text-slate-500 font-medium">Placing your order...</p>
        </div>
    }
    else
    {
        <div class="p-6 space-y-10 flex-1">
            <!-- Shipping Information -->
            <section>
                <h2 class="text-xl font-bold text-gray-900 mb-6">Shipping Information</h2>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-tight mb-2">Full Name</label>
                        <input type="text" @bind="profile.FullName" placeholder="Enter full name"
                               class="w-full px-4 py-3 bg-gray-50 border border-transparent rounded-xl focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-tight mb-2">Phone Number</label>
                        <input type="text" @bind="profile.PhoneNumber" placeholder="Enter phone number"
                               class="w-full px-4 py-3 bg-gray-50 border border-transparent rounded-xl focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-tight mb-2">Shipping Address</label>
                        <textarea @bind="profile.ShippingAddress" rows="3" placeholder="Enter complete address"
                                  class="w-full px-4 py-3 bg-gray-50 border border-transparent rounded-xl focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all resize-none"></textarea>
                    </div>
                </div>
            </section>

            <!-- Payment Method -->
            <section>
                <h2 class="text-xl font-bold text-gray-900 mb-6">Payment Method</h2>
                <div class="bg-gray-50 rounded-3xl p-6 space-y-6">
                    <label class="flex items-center gap-4 cursor-pointer group">
                        <div class="relative flex items-center justify-center">
                            <input type="radio" name="payment" value="COD" checked="@(paymentMethod == "COD")" @onchange='() => paymentMethod = "COD"'
                                   class="appearance-none w-6 h-6 border-2 border-gray-300 rounded-full checked:border-temu-orange transition-all" />
                            @if (paymentMethod == "COD")
                            {
                                <div class="absolute w-3 h-3 bg-black rounded-full"></div>
                            }
                        </div>
                        <span class="text-sm font-medium text-gray-700">Cash on Delivery (COD)</span>
                    </label>

                    <label class="flex items-center gap-4 cursor-pointer group">
                        <div class="relative flex items-center justify-center">
                            <input type="radio" name="payment" value="GCash" checked="@(paymentMethod == "GCash")" @onchange='() => paymentMethod = "GCash"'
                                   class="appearance-none w-6 h-6 border-2 border-gray-300 rounded-full checked:border-temu-orange transition-all" />
                            @if (paymentMethod == "GCash")
                            {
                                <div class="absolute w-3 h-3 bg-black rounded-full"></div>
                            }
                        </div>
                        <span class="text-sm font-medium text-gray-700">GCash</span>
                    </label>

                    <label class="flex items-center gap-4 cursor-pointer group">
                        <div class="relative flex items-center justify-center">
                            <input type="radio" name="payment" value="Card" checked="@(paymentMethod == "Card")" @onchange='() => paymentMethod = "Card"'
                                   class="appearance-none w-6 h-6 border-2 border-gray-300 rounded-full checked:border-temu-orange transition-all" />
                            @if (paymentMethod == "Card")
                            {
                                <div class="absolute w-3 h-3 bg-black rounded-full"></div>
                            }
                        </div>
                        <span class="text-sm font-medium text-gray-700">Credit/Debit Card</span>
                    </label>
                </div>
            </section>

            <!-- Order Summary -->
            <section>
                <h2 class="text-xl font-bold text-gray-900 mb-4">Order Summary</h2>
                <div class="bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm">
                    <div class="p-6 space-y-4">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-500">Items Subtotal (@cartItems.Sum(i => i.Quantity))</span>
                            <span class="text-gray-900 font-medium">₱@Subtotal.ToString("N2")</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-500">Shipping Fee (@cartItems.Select(i => i.SellerId).Distinct().Count() sellers)</span>
                            <span class="text-gray-900 font-medium">₱@((cartItems.Select(i => i.SellerId).Distinct().Count() * 80).ToString("N2"))</span>
                        </div>
                        <div class="pt-4 border-t border-gray-50 flex justify-between items-center">
                            <span class="text-base font-bold text-gray-800">Total Amount</span>
                            <span class="text-2xl font-black text-temu-orange">₱@((Subtotal + (cartItems.Select(i => i.SellerId).Distinct().Count() * 80)).ToString("N2"))</span>
                        </div>
                    </div>
                    <div class="bg-orange-50/50 px-6 py-3 text-[10px] text-temu-orange font-bold uppercase tracking-widest text-center border-t border-orange-100/50">
                        Including VAT where applicable
                    </div>
                </div>
            </section>
        </div>

        <!-- Footer Action -->
        <div class="mt-auto p-6 border-t border-gray-50 bg-white sticky bottom-0">
            <button @onclick="PlaceOrder" 
                    disabled="@(cartItems.Count == 0 || string.IsNullOrWhiteSpace(profile.ShippingAddress))"
                    class="w-full py-4 bg-temu-orange text-white rounded-full font-bold text-lg shadow-lg shadow-temu-orange/20 hover:bg-orange-600 transition-all disabled:opacity-50">
                PLACE ORDER
            </button>
        </div>
    }
</div>

@code {
    private List<CartItem> cartItems = new();
    private UserProfile profile = new();
    private bool isPlacingOrder;
    private string paymentMethod = "COD";
    private double Subtotal => cartItems.Sum(i => i.Price * i.Quantity);

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        cartItems = await FirebaseService.GetCartItemsAsync(AuthService.UserId!);
        if (!cartItems.Any())
        {
            Navigation.NavigateTo("/cart");
            return;
        }

        profile = await FirebaseService.GetUserProfileAsync(AuthService.UserId!);
    }

    private async Task PlaceOrder()
    {
        if (string.IsNullOrWhiteSpace(profile.FullName) || string.IsNullOrWhiteSpace(profile.ShippingAddress))
        {
            await JS.InvokeVoidAsync("alert", "Please complete your shipping information.");
            return;
        }

        isPlacingOrder = true;

        foreach (var item in cartItems)
        {
            var latestProduct = await FirebaseService.GetProductByIdAsync(item.ProductId);
            if (latestProduct == null)
            {
                await JS.InvokeVoidAsync("alert", $"The item '{item.Title}' is no longer available.");
                isPlacingOrder = false;
                return;
            }
            if (latestProduct.Stock <= 0)
            {
                await JS.InvokeVoidAsync("alert", $"The item '{item.Title}' is out of stock.");
                isPlacingOrder = false;
                return;
            }
            if (item.Quantity > latestProduct.Stock)
            {
                await JS.InvokeVoidAsync("alert", $"The item '{item.Title}' lacks stock. Only {latestProduct.Stock} available.");
                isPlacingOrder = false;
                return;
            }
        }

        // Group items by seller for order splitting
        var ordersBySeller = cartItems.GroupBy(i => i.SellerId);

        foreach (var group in ordersBySeller)
        {
            var sellerItems = group.ToList();
            var sellerSubtotal = sellerItems.Sum(i => i.Price * i.Quantity);

            var order = new Order
            {
                BuyerId = AuthService.UserId!,
                SellerId = group.Key,
                SellerName = sellerItems[0].SellerName,
                Items = sellerItems,
                Subtotal = sellerSubtotal,
                ShippingFee = 80, // Updated 1:1 with MAUI
                TotalPrice = sellerSubtotal + 80,
                Status = "Pending",
                PaymentMethod = paymentMethod,
                OrderDate = DateTime.Now,
                ReceiverName = profile.FullName,
                ReceiverPhone = profile.PhoneNumber,
                ShippingAddress = profile.ShippingAddress
            };

            await FirebaseService.PlaceOrderAsync(order);
        }

        // Clear cart and save profile
        await FirebaseService.ClearCartAsync(AuthService.UserId!);
        await FirebaseService.SaveUserProfileAsync(profile);

        await JS.InvokeVoidAsync("alert", "Order placed successfully!");
        Navigation.NavigateTo("/orders"); 
        isPlacingOrder = false;
    }
}
