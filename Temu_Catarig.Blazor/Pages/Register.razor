@page "/register"
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Create Account | Temu</PageTitle>

<div class="flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-2xl shadow-sm border border-gray-100">
        <div class="text-center">
            <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Join Us</h1>
            <p class="text-gray-500 text-sm">Create an account to start shopping</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="bg-red-50 border-l-4 border-red-400 p-4 text-red-700 text-sm">
                @errorMessage
            </div>
        }

        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" class="mt-8 space-y-6">
            <DataAnnotationsValidator />
            
            <div class="space-y-4">
                <div>
                    <InputText id="email" @bind-Value="registerModel.Email" 
                               class="appearance-none block w-full px-4 py-3 bg-gray-50 border border-transparent rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-temu-orange/20 focus:bg-white transition-all sm:text-sm" 
                               placeholder="Gmail" />
                    <ValidationMessage For="@(() => registerModel.Email)" class="text-red-500 text-[10px] mt-1" />
                </div>
                <div>
                    <InputText id="password" type="password" @bind-Value="registerModel.Password" 
                               class="appearance-none block w-full px-4 py-3 bg-gray-50 border border-transparent rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-temu-orange/20 focus:bg-white transition-all sm:text-sm" 
                               placeholder="Password" />
                    <ValidationMessage For="@(() => registerModel.Password)" class="text-red-500 text-[10px] mt-1" />
                </div>
                <div>
                    <InputText id="confirm" type="password" @bind-Value="registerModel.ConfirmPassword" 
                               class="appearance-none block w-full px-4 py-3 bg-gray-50 border border-transparent rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-temu-orange/20 focus:bg-white transition-all sm:text-sm" 
                               placeholder="Confirm Password" />
                    <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="text-red-500 text-[10px] mt-1" />
                </div>
            </div>

            <div class="space-y-6">
                <button type="submit" disabled="@isSubmitting"
                        class="group relative w-full flex justify-center py-4 px-4 border border-transparent text-sm font-bold rounded-full text-white bg-black hover:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black disabled:opacity-50 transition-all">
                    @if (isSubmitting)
                    {
                        <svg class="animate-spin h-5 w-5 mr-3 text-white" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    }
                    REGISTER
                </button>

                <p class="text-center text-sm text-gray-500">
                    Already have an account? 
                    <NavLink href="/login" class="font-bold text-temu-orange hover:underline">Sign In</NavLink>
                </p>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private bool isSubmitting;

    private async Task HandleRegister()
    {
        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        errorMessage = null;
        isSubmitting = true;

        var result = await AuthService.RegisterUser(registerModel.Email, registerModel.Password);
        
        if (result.Success)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = result.ErrorMessage;
        }

        isSubmitting = false;
    }

    public class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(6)]
        public string Password { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
