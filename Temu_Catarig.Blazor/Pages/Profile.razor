@page "/profile"
@implements IDisposable
@inject Temu_Catarig.Blazor.Services.AuthService AuthService
@inject Temu_Catarig.Blazor.Services.FirebaseService FirebaseService
@inject NavigationManager Navigation

<PageTitle>Account Hub - Temu</PageTitle>

@if (isLoading)
{
    <div class="flex justify-center items-center h-64">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-temu-orange"></div>
    </div>
}
else if (!AuthService.IsLoggedIn)
{
    <div class="max-w-[1200px] mx-auto p-4 text-center mt-10">
        <h2 class="text-2xl font-bold mb-4 text-slate-800">Please sign in to view your profile</h2>
        <button class="bg-temu-orange text-white py-2 px-8 rounded-full font-medium hover:bg-opacity-90 transition-colors shadow-md" @onclick='() => Navigation.NavigateTo("/login")'>Sign In</button>
    </div>
}
else
{
    <div class="max-w-[1200px] mx-auto p-4 md:p-6 pb-24 md:pb-6">
        <!-- Banner -->
        <div class="bg-temu-orange rounded-2xl p-6 md:p-10 text-white flex items-center gap-6 mb-8 shadow-lg relative overflow-hidden">
            <!-- Decorative circle -->
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-white opacity-10 rounded-full blur-2xl"></div>
            
            <div class="w-20 h-20 md:w-24 md:h-24 bg-white/20 rounded-full flex items-center justify-center text-3xl md:text-4xl font-bold border-4 border-white/30 backdrop-blur-sm z-10 shadow-sm">
                @(userProfile?.FullName?.FirstOrDefault().ToString()?.ToUpper() ?? AuthService.UserEmail?.FirstOrDefault().ToString()?.ToUpper() ?? "U")
            </div>
            <div class="z-10">
                <h1 class="text-2xl md:text-3xl font-bold mb-1 drop-shadow-sm">
                    @(string.IsNullOrWhiteSpace(userProfile?.FullName) ? (AuthService.UserDisplayName ?? "Temu User") : userProfile.FullName)
                </h1>
                <p class="text-white/90 font-medium tracking-wide">@AuthService.UserEmail</p>
            </div>
        </div>

        <!-- Tiles Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
            <!-- My Orders Tile -->
            <a href="/orders" class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-200 border border-slate-100 flex flex-col items-center text-center group cursor-pointer hover:-translate-y-1">
                <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center text-blue-500 mb-4 group-hover:scale-110 group-hover:bg-blue-100 transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-1">My Orders</h3>
                <p class="text-sm text-slate-500">Track, return, or buy things again</p>
            </a>

            <!-- Edit Profile Tile -->
            <a href="/profile/edit" class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-200 border border-slate-100 flex flex-col items-center text-center group cursor-pointer hover:-translate-y-1">
                <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center text-green-500 mb-4 group-hover:scale-110 group-hover:bg-green-100 transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-1">Edit Profile</h3>
                <p class="text-sm text-slate-500">Manage your address and details</p>
            </a>

            <!-- Seller Tools Tile -->
            @if (AuthService.IsAdmin)
            {
                <a href="/admin/dashboard" class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-200 border border-slate-100 flex flex-col items-center text-center group cursor-pointer hover:-translate-y-1">
                    <div class="w-16 h-16 bg-purple-50 rounded-full flex items-center justify-center text-purple-500 mb-4 group-hover:scale-110 group-hover:bg-purple-100 transition-all duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    </div>
                    <h3 class="text-lg font-bold text-slate-800 mb-1">Seller Tools</h3>
                    <p class="text-sm text-slate-500">Manage products and shop settings</p>
                </a>
            }
            
            <!-- Logout Tile -->
            <button @onclick="Logout" class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-200 border border-slate-100 flex flex-col items-center text-center group cursor-pointer hover:-translate-y-1">
                <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center text-red-500 mb-4 group-hover:scale-110 group-hover:bg-red-100 transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-1">Sign Out</h3>
                <p class="text-sm text-slate-500">Log out of your account</p>
            </button>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private Temu_Catarig.Blazor.Models.UserProfile? userProfile;

    protected override async Task OnInitializedAsync()
    {
        AuthService.OnChange += StateHasChanged;
        
        if (AuthService.IsLoggedIn && !string.IsNullOrEmpty(AuthService.UserId))
        {
            userProfile = await FirebaseService.GetUserProfileAsync(AuthService.UserId);
        }
        
        isLoading = false;
    }
    
    public void Dispose()
    {
        AuthService.OnChange -= StateHasChanged;
    }

    private async Task Logout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }
}
