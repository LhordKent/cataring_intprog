@page "/orders"
@inject FirebaseService FirebaseService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>My Orders | Temu</PageTitle>

<div class="max-w-4xl mx-auto py-8 px-4">
    <div class="flex items-center gap-4 mb-8">
        <button @onclick='() => Navigation.NavigateTo("/profile")' class="p-2 hover:bg-gray-100 rounded-full transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <h1 class="text-2xl font-bold">My Orders</h1>
    </div>

    @if (orders == null)
    {
        <div class="space-y-4">
            @for (int i = 0; i < 3; i++)
            {
                <div class="h-40 bg-gray-100 animate-pulse rounded-xl"></div>
            }
        </div>
    }
    else if (!orders.Any())
    {
        <div class="text-center py-20 bg-white rounded-2xl border border-dashed border-gray-200">
            <p class="text-gray-500">No orders yet</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var order in orders)
            {
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <div class="flex flex-wrap justify-between items-start gap-4 mb-4 pb-4 border-b border-gray-50">
                        <div>
                            <p class="text-xs text-gray-400 uppercase font-bold tracking-wider mb-1">Order ID</p>
                            <p class="text-sm font-mono font-medium text-gray-700">#@order.Id?.ToUpper()</p>
                        </div>
                        <div class="text-right">
                            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase @GetStatusClass(order.Status)">
                                @order.Status
                            </span>
                            <p class="text-xs text-gray-400 mt-2">@order.OrderDate.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>

                    <div class="space-y-3 mb-4">
                        @foreach (var item in order.Items)
                        {
                            <div class="flex items-center gap-3">
                                <img src="@item.ImageUrl" class="w-10 h-10 rounded object-cover" alt="" />
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-gray-800 truncate">@item.Title</p>
                                    <p class="text-xs text-gray-500">Qty: @item.Quantity</p>
                                </div>
                                <p class="text-sm font-bold text-gray-900">₱@((item.Price * item.Quantity).ToString("N0"))</p>
                            </div>
                        }
                    </div>

                    <div class="flex justify-between items-center pt-2">
                        <p class="text-sm text-gray-500">Total Price</p>
                        <div class="flex items-center gap-4">
                            @if (!order.IsReviewed && order.Status == "Delivered")
                            {
                                <button @onclick="() => StartReview(order)" class="text-xs font-bold text-temu-orange border border-temu-orange px-4 py-1.5 rounded-full hover:bg-temu-orange hover:text-white transition-all uppercase">
                                    Review
                                </button>
                            }
                            else if (order.IsReviewed)
                            {
                                <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Reviewed</span>
                            }
                            <p class="text-lg font-bold text-temu-orange">₱@order.TotalPrice.ToString("N0")</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (reviewingOrder != null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
        <div class="bg-white w-full max-w-md rounded-3xl overflow-hidden shadow-2xl animate-in fade-in zoom-in duration-200">
            <div class="p-8">
                <h3 class="text-2xl font-extrabold text-gray-900 mb-2">Rate your purchase</h3>
                <p class="text-gray-500 text-sm mb-8">How would you rate your order from @reviewingOrder.SellerName?</p>
                
                <div class="flex justify-center gap-2 mb-8">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var starIndex = i;
                        <button @onclick="() => selectedRating = starIndex" class="transition-transform active:scale-95">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" 
                                 fill="@(selectedRating >= starIndex ? "#ff6000" : "none")" 
                                 stroke="@(selectedRating >= starIndex ? "#ff6000" : "#e2e8f0")" 
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                        </button>
                    }
                </div>

                <textarea @bind="reviewComment" rows="4" placeholder="What do you think about the product? (Optional)"
                          class="w-full px-4 py-3 bg-gray-50 border border-transparent rounded-2xl focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all resize-none mb-8"></textarea>

                <div class="flex gap-4">
                    <button @onclick="() => reviewingOrder = null" class="flex-1 py-4 text-gray-500 font-bold hover:text-gray-700 transition-colors uppercase text-sm">Cancel</button>
                    <button @onclick="SubmitReview" disabled="@(selectedRating == 0 || isSubmittingReview)"
                            class="flex-[2] py-4 bg-temu-orange text-white rounded-full font-bold text-sm shadow-lg shadow-temu-orange/20 hover:bg-orange-600 transition-all disabled:opacity-50 uppercase">
                        @if (isSubmittingReview)
                        {
                            <span class="inline-block animate-spin">◌</span>
                        }
                        else
                        {
                            <span>Submit Review</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Order>? orders;
    private Order? reviewingOrder;
    private int selectedRating = 0;
    private string reviewComment = "";
    private bool isSubmittingReview = false;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        try
        {
            orders = await FirebaseService.GetUserOrdersAsync(AuthService.UserId!);
            orders = orders.OrderByDescending(o => orderDateSafe(o)).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading orders: {ex.Message}");
            orders = new List<Order>();
        }
    }

    private void StartReview(Order order)
    {
        reviewingOrder = order;
        selectedRating = 0;
        reviewComment = "";
    }

    private async Task SubmitReview()
    {
        if (reviewingOrder == null || selectedRating == 0) return;

        isSubmittingReview = true;
        try
        {
            string buyerName = !string.IsNullOrWhiteSpace(AuthService.UserDisplayName) ? AuthService.UserDisplayName : (AuthService.UserEmail ?? "Customer");
            try
            {
                var profile = await FirebaseService.GetUserProfileAsync(AuthService.UserId!);
                if (profile != null && !string.IsNullOrWhiteSpace(profile.FullName))
                {
                    buyerName = profile.FullName;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error retrieving user profile for review: {ex.Message}");
            }

            var review = new Review
            {
                ProductId = reviewingOrder.Items[0].ProductId,
                BuyerId = AuthService.UserId!,
                BuyerName = buyerName,
                Rating = selectedRating,
                Comment = reviewComment,
                Timestamp = DateTime.Now
            };

            await FirebaseService.SubmitReviewAsync(review);
            await FirebaseService.UpdateOrderReviewStatusAsync(reviewingOrder.Id!, true);
            
            reviewingOrder = null;
            await LoadOrders();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error submitting review: {ex.Message}");
        }
        finally
        {
            isSubmittingReview = false;
        }
    }

    private DateTime orderDateSafe(Order o) => o.OrderDate == default ? DateTime.MinValue : o.OrderDate;

    private string GetStatusClass(string status) => status switch
    {
        "Delivered" => "bg-green-100 text-green-700",
        "Pending" => "bg-yellow-100 text-yellow-700",
        "Cancelled" => "bg-red-100 text-red-700",
        _ => "bg-blue-100 text-blue-700"
    };
}
