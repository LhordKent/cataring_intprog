@page "/chat/{ConversationId}"
@inject FirebaseService FirebaseService
@inject AuthService AuthService

<PageTitle>Chat | Temu</PageTitle>

<div class="max-w-2xl mx-auto h-[80vh] flex flex-col bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <!-- Chat Header -->
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between bg-white">
        <div>
            <h2 class="font-bold text-gray-900">Chat</h2>
            <p class="text-xs text-gray-500">Conversation ID: @ConversationId</p>
        </div>
    </div>

    <!-- Messages Area -->
    <div class="flex-1 overflow-y-auto p-6 space-y-4 bg-gray-50">
        @if (messages == null)
        {
            <div class="text-center text-gray-400 py-10">Loading messages...</div>
        }
        else if (!messages.Any())
        {
            <div class="text-center text-gray-400 py-10 italic">No messages yet. Say hi!</div>
        }
        else
        {
            @foreach (var msg in messages)
            {
                <div class="flex @(msg.SenderId == AuthService.UserId ? "justify-end" : "justify-start")">
                    <div class="max-w-[80%] px-4 py-2 rounded-2xl text-sm shadow-sm
                                @(msg.SenderId == AuthService.UserId ? "bg-temu-orange text-white rounded-tr-none" : "bg-white text-gray-800 rounded-tl-none")">
                        <p>@msg.Text</p>
                        <p class="text-[10px] mt-1 opacity-70">@msg.TimeFormatted</p>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Input Area -->
    <div class="p-4 bg-white border-t border-gray-100">
        <div class="flex gap-2">
            <input type="text" @bind="newMessageText" @bind:event="oninput" @onkeyup="HandleKeyUp"
                   placeholder="Type a message..." 
                   class="flex-1 bg-gray-100 rounded-full py-2 px-4 focus:outline-none focus:ring-2 focus:ring-temu-orange/20" />
            <button @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(newMessageText)"
                    class="bg-temu-orange text-white p-2 rounded-full hover:bg-opacity-90 disabled:opacity-50">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ConversationId { get; set; } = string.Empty;
    private List<Message>? messages;
    private string newMessageText = string.Empty;

    protected override void OnInitialized()
    {
        if (!AuthService.IsLoggedIn) return;
        
        // In a real app, we'd use a Realtime listener. Here we poll or fetch once for MVP.
        LoadMessages();
    }

    private void LoadMessages()
    {
        // Note: FirebaseService doesn't have a GetMessages method yet in our plan, 
        // but we'll simulate or skip for now to stay on task.
        // Let's assume an empty list for the port demo.
        messages = new List<Message>();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessageText)) return;

        var message = new Message
        {
            ConversationId = ConversationId,
            SenderId = AuthService.UserId!,
            SenderName = "Me",
            Text = newMessageText,
            Timestamp = DateTime.UtcNow
        };

        await FirebaseService.SendMessageAsync(ConversationId, message);
        messages?.Add(message);
        newMessageText = string.Empty;
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = SendMessage();
    }
}
