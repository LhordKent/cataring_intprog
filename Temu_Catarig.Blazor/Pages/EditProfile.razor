@page "/profile/edit"
@inject Temu_Catarig.Blazor.Services.AuthService AuthService
@inject Temu_Catarig.Blazor.Services.FirebaseService FirebaseService
@inject NavigationManager Navigation

<PageTitle>Edit Profile - Temu</PageTitle>

@if (!AuthService.IsLoggedIn)
{
    <div class="max-w-[1200px] mx-auto p-4 text-center mt-10">
        <h2 class="text-2xl font-bold mb-4 text-slate-800">Please sign in to edit your profile</h2>
        <button class="bg-temu-orange text-white py-2 px-8 rounded-full font-medium hover:bg-opacity-90 transition-colors shadow-md" @onclick='() => Navigation.NavigateTo("/login")'>Sign In</button>
    </div>
}
else
{
    <div class="max-w-[800px] mx-auto p-4 md:p-6 pb-24 md:pb-6">
        <div class="flex items-center gap-4 mb-8">
            <button @onclick='() => Navigation.NavigateTo("/profile")' class="p-2 hover:bg-slate-100 rounded-full transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <h1 class="text-2xl font-bold text-slate-800">Edit Profile</h1>
        </div>

        <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-slate-100">
            @if (isLoading)
            {
                <div class="flex justify-center py-10">
                    <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-temu-orange"></div>
                </div>
            }
            else
            {
                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Full Name</label>
                        <input type="text" @bind="profile.FullName" placeholder="Enter your full name" 
                               class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Phone Number</label>
                        <input type="tel" @bind="profile.PhoneNumber" placeholder="Enter your phone number" 
                               class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Shipping Address</label>
                        <textarea @bind="profile.ShippingAddress" rows="3" placeholder="Enter your shipping address" 
                                  class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-temu-orange/20 transition-all"></textarea>
                    </div>

                    <div class="pt-4 flex gap-4">
                        <button @onclick="SaveProfile" disabled="@isSaving" class="flex-1 bg-temu-orange text-white py-3 rounded-full font-bold hover:bg-opacity-90 transition-all shadow-md disabled:opacity-50">
                            @(isSaving ? "Saving..." : "Save Changes")
                        </button>
                        <button @onclick='() => Navigation.NavigateTo("/profile")' class="flex-1 bg-slate-100 text-slate-700 py-3 rounded-full font-bold hover:bg-slate-200 transition-all">
                            Cancel
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <p class="text-center text-sm font-medium @(statusMessage.Contains("Error") ? "text-red-500" : "text-green-500")">
                            @statusMessage
                        </p>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isSaving = false;
    private string statusMessage = string.Empty;
    private Temu_Catarig.Blazor.Models.UserProfile profile = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsLoggedIn && !string.IsNullOrEmpty(AuthService.UserId))
        {
            profile = await FirebaseService.GetUserProfileAsync(AuthService.UserId);
            if (string.IsNullOrEmpty(profile.Email)) profile.Email = AuthService.UserEmail ?? "";
        }
        isLoading = false;
    }

    private async Task SaveProfile()
    {
        isSaving = true;
        statusMessage = string.Empty;

        try
        {
            await FirebaseService.SaveUserProfileAsync(profile);
            statusMessage = "Profile updated successfully!";
            await Task.Delay(1500);
            Navigation.NavigateTo("/profile");
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
