@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager Navigation

<!-- Desktop Top Navbar -->
<nav class="hidden md:flex sticky top-0 z-50 bg-white border-b border-gray-200 px-6 py-3 items-center justify-between">
    <div class="flex items-center gap-8">
        <a href="/" class="text-2xl font-bold text-temu-orange italic">TEMU</a>
        
        <div class="relative w-96">
            <input type="text" placeholder="Search for anything..." 
                   class="w-full bg-gray-100 rounded-full py-2 px-4 pl-10 focus:outline-none focus:ring-2 focus:ring-temu-orange/20" />
            <div class="absolute left-3 top-2.5 text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
        </div>
    </div>

    <div class="flex items-center gap-6 text-gray-700">
        <NavLink href="/orders" class="flex flex-col items-center hover:text-temu-orange transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="text-xs mt-1">Orders</span>
        </NavLink>
        <NavLink href="/cart" class="flex flex-col items-center hover:text-temu-orange transition-colors relative">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
            <span class="text-xs mt-1">Cart</span>
        </NavLink>
        
        @if (!AuthService.IsLoggedIn)
        {
            <NavLink href="/login" class="bg-black text-white py-1.5 px-6 rounded-full font-medium hover:bg-gray-800 transition-colors">Sign In</NavLink>
        }
        else
        {
            <div class="flex items-center gap-4">
                <span class="text-sm font-medium text-slate-500">Hi, @(!string.IsNullOrWhiteSpace(AuthService.UserDisplayName) ? AuthService.UserDisplayName : (!string.IsNullOrWhiteSpace(AuthService.UserEmail) ? AuthService.UserEmail : "User"))</span>
                <button @onclick="Logout" class="text-sm font-medium hover:text-temu-orange">Sign Out</button>
            </div>
        }
    </div>
</nav>

<!-- Mobile Top Search (Sticky) -->
<div class="md:hidden sticky top-0 z-50 bg-white px-4 py-2 border-b border-gray-100 flex items-center gap-3">
    <div class="relative flex-1">
        <input type="text" placeholder="Temu" 
               class="w-full bg-gray-100 rounded-full py-1.5 px-4 pl-10 text-sm focus:outline-none" />
        <div class="absolute left-3 top-2 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
    </div>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
</div>

<!-- Mobile Bottom Navigation Bar -->
<nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-gray-200 px-2 py-1 flex items-center justify-around shadow-[0_-2px_10px_rgba(0,0,0,0.05)]">
    <NavLink href="/" Match="NavLinkMatch.All" class="flex flex-col items-center p-2 text-gray-500" ActiveClass="text-temu-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span class="text-[10px] mt-1 font-medium">Home</span>
    </NavLink>
    <NavLink href="/categories" class="flex flex-col items-center p-2 text-gray-500" ActiveClass="text-temu-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
        <span class="text-[10px] mt-1 font-medium">Categories</span>
    </NavLink>
    <NavLink href="/profile" class="flex flex-col items-center p-2 text-gray-500" ActiveClass="text-temu-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span class="text-[10px] mt-1 font-medium">You</span>
    </NavLink>
    <NavLink href="/cart" class="flex flex-col items-center p-2 text-gray-500 relative" ActiveClass="text-temu-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
        <span class="text-[10px] mt-1 font-medium">Cart</span>
    </NavLink>
</nav>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnChange += StateHasChanged;
        Navigation.LocationChanged += HandleLocationChanged;
    }

    public void Dispose()
    {
        AuthService.OnChange -= StateHasChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private async Task Logout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }
}
